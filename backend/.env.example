# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (from Neon dashboard → Connection Details → Prisma)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/swasthconnect?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT tokens — generate with: openssl rand -base64 64
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_SECRET"

# ─── AI — Google Gemini Flash ─────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="REPLACE_WITH_GEMINI_API_KEY"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="REPLACE_WITH_CLOUD_NAME"
CLOUDINARY_API_KEY="REPLACE_WITH_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="REPLACE_WITH_CLOUDINARY_API_SECRET"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Vercel frontend URL — allows only this origin for CORS
# Local dev: http://localhost:5173
CLIENT_URL="http://localhost:5173"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
