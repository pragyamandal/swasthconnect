# ─── API ─────────────────────────────────────────────────────────────────────
# Backend API base URL (without trailing slash)
# Local dev:  http://localhost:3001
# Production: https://swasthconnect-api.onrender.com
VITE_API_URL="http://localhost:3001"

# ─── PeerJS ──────────────────────────────────────────────────────────────────
# Self-hosted PeerServer URL and path (running on the same Render instance as the backend)
# Local dev: http://localhost:3001
VITE_PEERJS_HOST="localhost"
VITE_PEERJS_PORT="3001"
VITE_PEERJS_PATH="/peerjs"
